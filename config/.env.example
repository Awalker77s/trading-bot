ALPACA_KEY=YOUR_ALPACA_KEY
ALPACA_SECRET=YOUR_ALPACA_SECRET
ALPACA_PAPER=true
ENDPOINT=https://paper-api.alpaca.markets/v2

# ── Bot Monitoring ────────────────────────────────────────────────────────────
# Optional Discord / Slack / generic webhook URL for trade and error alerts.
# Leave unset (or empty) to disable all webhook notifications.
WEBHOOK_URL=

# Notify when a trade entry or exit is placed. Default: true
NOTIFY_ON_TRADES=true

# Notify when the daily loss kill-switch fires or an error occurs. Default: true
NOTIFY_ON_ERRORS=true

# Send a brief summary message after every run completes. Default: false
# Enable this only if your bot runs infrequently (e.g. once per day).
NOTIFY_ON_SUMMARY=false
