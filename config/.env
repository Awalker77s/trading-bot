# Copy this file to config/.env and fill in real values.
ALPACA_KEY=YOUR_ALPACA_KEY
ALPACA_SECRET=YOUR_ALPACA_SECRET
ALPACA_PAPER=true
ENDPOINT=https://paper-api.alpaca.markets/v2

# ── Crypto Bot Parameters ──────────────────────────────────────────────────────
# All values below are optional — defaults are baked in if left unset.
#
#CRYPTO_RISK_PER_TRADE=0.01         # Fraction of equity risked per trade (1%)
#CRYPTO_MAX_POSITION_PCT=0.12       # Max position size as fraction of equity (12%)
#CRYPTO_MAX_OPEN_POSITIONS=3        # Max concurrent crypto positions
#CRYPTO_MIN_NOTIONAL_USD=25.0       # Minimum order size in USD
#CRYPTO_STOP_ATR_MULTIPLIER=2.2     # ATR multiplier for stop loss distance
#CRYPTO_TARGET_ATR_MULTIPLIER=3.8   # ATR multiplier for take-profit distance
#CRYPTO_MIN_ATR_PCT=0.004           # Minimum ATR/price ratio to trade (0.4%)
#CRYPTO_MAX_ATR_PCT=0.10            # Maximum ATR/price ratio to trade (10%)
#CRYPTO_LOOKBACK_DAYS=220           # Days of daily bars to fetch per symbol
#CRYPTO_MAX_DAILY_LOSS_PCT=0.02     # Daily loss kill-switch as fraction of equity (2%)
#CRYPTO_RUN_INTERVAL_SECONDS=900    # Seconds to sleep between run cycles (900 = 15 min)
